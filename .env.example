# PostgreSQL
POSTGRES_DB=foundry
POSTGRES_USER=foundry
POSTGRES_PASSWORD=foundry_dev_password

# Local runs from the host machine
DATABASE_URL=postgresql+asyncpg://foundry:foundry_dev_password@localhost:5432/foundry
ARTIFACT_DIR=./artifacts

# Docker Compose container-to-container settings
COMPOSE_DATABASE_URL=postgresql+asyncpg://foundry:foundry_dev_password@postgres:5432/foundry
DOCKER_ARTIFACT_DIR=/app/artifacts

# Storage and job backends
STORAGE_BACKEND=local
JOB_BACKEND=local
GCS_BUCKET=
CLOUD_TASKS_PROJECT_ID=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_WORKER_URL=
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=
CLOUD_TASKS_AUDIENCE=

# Worker
POLL_INTERVAL_SECONDS=2

# App runtime
ENVIRONMENT=development
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:8000
